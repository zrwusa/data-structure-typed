    "graph",
    "directed graph",
    "undirected graph",
    "hash map",
    "hash table",
    "segment tree",
    "binary indexed tree",
    "fenwick tree",
    "matrix",
    "rank query",
    "range query",
    "order statistic tree",
    "getRank",
