    "rangeByRank",
    "dijkstra",
    "bellman ford",
    "topological sort",
    "DFS",
    "BFS",
    "leetcode",
    "coding interview",
    "algorithm",
    "zero dependency",
    "production ready",
    "type safe",
    "ES6",
    "CommonJS",
    "UMD",
    "collection",
    "sorted collection"
  ]
}
